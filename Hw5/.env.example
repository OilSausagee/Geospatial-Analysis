# Environment variables for Week 5 Assignment
# Copy this file to .env and update with your actual values

# App configuration
APP_MODE=SIMULATION
CWA_API_KEY=your-cwa-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Data paths
SIMULATION_DATA=data/fungwong_202511.json

# Analysis thresholds (mm/hr)
RAINFALL_CRITICAL_THRESHOLD=80.0
RAINFALL_URGENT_THRESHOLD=40.0

# Spatial analysis
BUFFER_DISTANCE_KM=5.0

# Target counties
TARGET_COUNTY=花蓮縣
