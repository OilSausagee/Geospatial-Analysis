# Week 12 ARIA v8.0 — Environment variables (do NOT commit the real .env)
# Case Study: 2024 花蓮地震後秀林 / 太魯閣土地覆蓋分類（M7.4, 2024-04-03）

# ── 研究區 BBOX (W,S,E,N) — Xiulin / Taroko ──
BBOX_WEST=121.40
BBOX_SOUTH=24.10
BBOX_EAST=121.80
BBOX_NORTH=24.25

# ── STAC 搜尋（漸進式三階段）──
PHASE1_RANGE=2024-04-15/2024-05-31
PHASE1_CC=20
PHASE2_RANGE=2024-04-03/2024-08-31
PHASE2_CC=30
PHASE3_RANGE=2024-04-03/2024-12-31
PHASE3_CC=50

# ── Sentinel-2 影像參數 ──
RESOLUTION=20            # 20 m grid（B11/B12 原生 20 m，避免重採樣失真）
KMEANS_K=5
RF_TREES=200
RANDOM_STATE=42

# ── SWCB 崩塌資料 ──
SWCB_KML=data/20240802新生崩塌地.kml

# ── Output ──
OUTPUT_DIR=output

# ── Gemini（沿用 W9/W10）──
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
