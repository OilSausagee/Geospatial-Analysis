# Environment Configuration Template
# Copy this to .env and fill in your actual API keys

# Application Mode
APP_MODE=SIMULATION

# CWA API Configuration
CWA_API_KEY=YOUR_CWA_API_KEY_HERE

# Simulation Data Path
SIMULATION_DATA=Hw5/data/fungwong_202511.json

# Target County
TARGET_COUNTY=花蓮縣

# Rainfall Thresholds (mm/hr)
RAINFALL_CRITICAL_THRESHOLD=80
RAINFALL_URGENT_THRESHOLD=40
RAINFALL_WARNING_THRESHOLD=0

# Buffer Configuration
BUFFER_DISTANCE_KM=5

# Map Configuration
MAP_CENTER_LAT=23.8
MAP_CENTER_LON=121.6
MAP_ZOOM_START=10

# Data Paths
SHELTERS_DATA=Hw5/data/避難收容處所.csv
TERRAIN_RISK_DATA=Hw5/data/terrain_risk_audit.json
OUTPUTS_DIR=Hw5/outputs

# AI Configuration
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
